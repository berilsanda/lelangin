{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "esnext",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
      "@firebase/auth": ["./node_modules/@firebase/auth/dist/rn/index.rn.d.ts"]
    },
    "types": ["expo-router/types", "node", "jest"]
  }
}
